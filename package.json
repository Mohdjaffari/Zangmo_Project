{
  "name": "zangmo-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:build": "npm run build && electron-packager . \"ZangmoPOS\" --platform=win32 --arch=x64 --out=dist-desktop --overwrite"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.2.0",
    "electron": "^28.2.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "electron-packager": "^17.1.2"
  }
}
